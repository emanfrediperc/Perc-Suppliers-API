# Server
PORT=3100
CORS_ORIGIN=http://localhost:4200

# MongoDB
MONGODB_URI=mongodb://localhost:27017/perc-suppliers

# JWT
JWT_SECRET=replace-with-32-plus-char-random-string-please
JWT_EXPIRES_IN=24h

# AWS S3 (Storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=perc-suppliers-facturas
AWS_S3_ENDPOINT=

# Google Gemini (OCR)
GEMINI_API_KEY=your-gemini-api-key

# Email (optional). Two modes — Resend HTTP API (preferred, works where
# SMTP is blocked like Railway) or SMTP via nodemailer. If RESEND_API_KEY
# is set, SMTP is ignored.

# Resend HTTP API (recommended)
RESEND_API_KEY=

# SMTP fallback
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

EMAIL_FROM=noreply@perc-suppliers.com

# Finnegans ERP (optional — if empty, uses mock data)
FINNEGANS_BASE_URL=https://api.teamplace.finneg.com
FINNEGANS_AUTH_URL=https://api.teamplace.finneg.com/oauth/token
FINNEGANS_CLIENT_ID=your-finnegans-client-id
FINNEGANS_CLIENT_SECRET=your-finnegans-client-secret

# AFIP — WSAA + ws_sr_padron_a5 (constancia de inscripción)
# Si cualquiera de los 3 falta, las consultas devuelven null sin romper la API.
AFIP_ENV=homologacion
AFIP_CERT_PATH=./certs/afip.crt
AFIP_KEY_PATH=./certs/afip.key
AFIP_CUIT_REPRESENTADO=

# Apócrifos AFIP — bloqueante en creación de factura.
# Requiere cuenta en 2captcha.com (API key). Si TWOCAPTCHA_API_KEY está vacío,
# la verificación se saltea (no bloquea). Cache de resultados en Mongo.
TWOCAPTCHA_API_KEY=
APOCRIFOS_CACHE_DAYS=30
# Cron diario a las 3am: invalida cache y re-consulta apócrifos para
# proveedores con facturas creadas en los últimos N días.
APOCRIFOS_RECHECK_WINDOW_DAYS=90

# RFC 3161 Time Stamping Authority — sello de tiempo en transiciones de SolicitudPago
# Si TSA_ENABLED=false o el TSA no responde dentro del timeout, el historial sigue
# protegido por hash encadenado pero sin token TSA. La transición no se bloquea.
TSA_ENABLED=true
TSA_URL=https://freetsa.org/tsr
TSA_TIMEOUT_MS=3000

# Recordatorio diario a contabilidad: si una solicitud lleva > N horas en pendiente,
# el cron de las 9am reenvía email con la lista.
SOLICITUD_PAGO_REMINDER_HOURS=24

# Magic link para decisiones de aprobación sin login (default: desactivado)
ENABLE_MAGIC_LINK=false
MAGIC_LINK_BASE_URL=http://localhost:4200/aprobar
MAGIC_LINK_TTL_HOURS=48

# Seed (optional — random if unset, required in production with ALLOW_SEED=1)
SEED_PASSWORD=
ALLOW_SEED=

# MongoDB credentials (required when using docker-compose with --auth)
MONGO_ROOT_USER=
MONGO_ROOT_PASS=
